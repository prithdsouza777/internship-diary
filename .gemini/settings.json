{
    "security": {
        "autoPermissions": {
            "default_api": {
                "mcp_mcp-obsidian_obsidian_append_content": true,
                "run_shell_command": true
            }
        }
    },
    "tools": {
        "shell": {
            "enableInteractiveShell": false,
            "showColor": true,
            "allowedCommands": [
                "cd",
                "git add Internship_Diary.md",
                "git commit",
                "git push origin main",
                "git status",
                "python auto_fill.py",
                "Get-Content",
                "Add-Content",
                "cat",
                "echo"
            ]
        },
        "mcp": {
            "allowedTools": [
                "obsidian_get_file_contents",
                "obsidian_append_content",
                "obsidian_patch_content",
                "obsidian_simple_search",
                "obsidian_list_files_in_vault",
                "obsidian_create_note"
            ]
        }
    },
    "skills": {
        "enabled": true,
        "allowedSkills": [
            "diary-writer",
            "git-push",
            "obsidian-sync",
            "context-manager",
            "auto-fill"
        ]
    }
}